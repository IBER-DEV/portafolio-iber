---
// Experience Component - Animated Timeline with Video Accents
---

<section class="experience section" id="experience">
  <div class="container">
    <h2 class="section-title scroll-reveal">
      <span class="gradient-text">Experiencia Profesional</span>
    </h2>
    
    <div class="timeline">
      <div class="timeline-item scroll-reveal-left">
        <div class="timeline-card card">
          <div class="timeline-header">
            <div class="company-logo" aria-hidden="true"><i class="ti ti-building-skyscraper"></i></div>
            <div class="company-info">
              <h3>Tecnoglass</h3>
              <p class="role">Analista de Aplicaciones</p>
            </div>
          </div>
          <div class="timeline-date">
            <span class="date-badge">Marzo 2026 - Actualidad</span>
          </div>
          <ul class="responsibilities">
            <li>
              <span class="bullet">▹</span>
              Diseño y desarrollo de plataformas web
            </li>
            <li>
              <span class="bullet">▹</span>
              Implementación de soluciones cliente/servidor
            </li>
            <li>
              <span class="bullet">▹</span>
              Integración de tecnologías y dispositivos
            </li>
            <li>
              <span class="bullet">▹</span>
              Optimización de procesos mediante software
            </li>
          </ul>
        </div>
      </div>
      
      <div class="timeline-item scroll-reveal-right">
        <div class="timeline-card card">
          <div class="timeline-header">
            <div class="company-logo" aria-hidden="true"><i class="ti ti-code"></i></div>
            <div class="company-info">
              <h3>Tecnoglass</h3>
              <p class="role">Ingeniero de Desarrollo de Software</p>
            </div>
          </div>
          <div class="timeline-date">
            <span class="date-badge secondary">Junio 2025 - Diciembre 2025</span>
          </div>
          <ul class="responsibilities">
            <li>
              <span class="bullet">▹</span>
              Desarrollo de software empresarial
            </li>
            <li>
              <span class="bullet">▹</span>
              Implementación de soluciones tecnológicas
            </li>
          </ul>
        </div>
      </div>
      
      <div class="timeline-item scroll-reveal-left">
        <div class="timeline-card card">
          <div class="timeline-header">
            <div class="company-logo" aria-hidden="true"><i class="ti ti-briefcase-2"></i></div>
            <div class="company-info">
              <h3>Freelance (Autónomo)</h3>
              <p class="role">Desarrollador Full Stack</p>
            </div>
          </div>
          <div class="timeline-date">
            <span class="date-badge tertiary">Enero 2019 - Septiembre 2025</span>
          </div>
          <ul class="responsibilities">
            <li>
              <span class="bullet">▹</span>
              Desarrollo de soluciones personalizadas para pequeños negocios
            </li>
            <li>
              <span class="bullet">▹</span>
              Implementación de aplicaciones web con Angular y Next.js
            </li>
            <li>
              <span class="bullet">▹</span>
              Integración de bases de datos SQL
            </li>
            <li>
              <span class="bullet">▹</span>
              Participación en ferias tecnológicas con proyectos innovadores
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .experience {
    background: var(--color-bg-secondary);
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
  }
  
  .timeline {
    position: relative;
    padding-left: 3rem;
    max-width: 850px;
    margin: 0 auto;
  }
  
  .timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(180deg, var(--color-accent-pink), var(--color-accent-cyan), var(--color-accent-purple));
    box-shadow: 0 0 15px rgba(201, 104, 69, 0.25);
  }
  
  .timeline-item {
    position: relative;
    margin-bottom: 3rem;
  }
  
  .timeline-item::before {
    content: '';
    position: absolute;
    left: calc(-3rem - 6px);
    top: 1.5rem;
    width: 14px;
    height: 14px;
    background: var(--color-accent-pink);
    border-radius: 50%;
    box-shadow: 0 0 20px rgba(201, 104, 69, 0.45), 0 0 40px rgba(201, 104, 69, 0.2);
    transition: transform 0.3s var(--ease-out-quart), box-shadow 0.3s ease;
    z-index: 1;
  }
  
  .timeline-item:hover::before {
    transform: scale(1.6);
    box-shadow: 0 0 30px rgba(201, 104, 69, 0.65), 0 0 60px rgba(201, 104, 69, 0.28);
  }
  
  .timeline-card {
    background: var(--color-surface-2);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    border: 1px solid var(--color-border-soft);
    transition: all 0.4s var(--ease-out-quart);
    position: relative;
    overflow: hidden;
  }
  
  .timeline-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(201, 104, 69, 0.08), rgba(122, 195, 182, 0.08));
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  
  .timeline-card:hover {
    transform: translateX(8px);
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-lg);
  }
  
  .timeline-card:hover::before {
    opacity: 1;
  }
  
  .timeline-header {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
    position: relative;
    z-index: 1;
  }
  
  .company-logo {
    width: 60px;
    height: 60px;
    background: rgba(214, 178, 106, 0.08);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.65rem;
    color: var(--color-accent-yellow);
    flex-shrink: 0;
    border: 1px solid rgba(214, 178, 106, 0.3);
  }
  
  .company-info h3 {
    font-size: var(--text-2xl);
    font-weight: 700;
    margin-bottom: var(--space-1);
    color: var(--color-text-primary);
  }
  
  .role {
    color: var(--color-accent-cyan);
    font-weight: 500;
    font-size: var(--text-lg);
  }
  
  .timeline-date {
    margin-bottom: var(--space-6);
    position: relative;
    z-index: 1;
  }
  
  .date-badge {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    background: rgba(201, 104, 69, 0.14);
    color: var(--color-accent-pink);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    font-weight: 500;
  }
  
  .date-badge.secondary {
    background: rgba(122, 195, 182, 0.14);
    color: var(--color-accent-cyan);
  }
  
  .date-badge.tertiary {
    background: rgba(143, 138, 166, 0.14);
    color: var(--color-accent-purple);
  }
  
  .responsibilities {
    display: grid;
    gap: var(--space-3);
    position: relative;
    z-index: 1;
  }
  
  .responsibilities li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    color: var(--color-text-secondary);
    line-height: 1.6;
    font-size: var(--text-base);
  }
  
  .bullet {
    color: var(--color-accent-pink);
    font-weight: 600;
    flex-shrink: 0;
  }
  
  @media (max-width: 768px) {
    .timeline {
      padding-left: 2rem;
    }
    
    .timeline-item::before {
      left: calc(-2rem - 6px);
    }
    
    .timeline-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
