---
// Contact Component - Cinematic Contact Section
---

<section class="contact section" id="contact">
  <div class="container">
    <h2 class="section-title scroll-reveal">
      <span class="gradient-text">Contacto</span>
    </h2>
    
    <div class="contact-grid">
      <div class="contact-info scroll-reveal-left">
        <h3>¡Hablemos!</h3>
        <p class="contact-description">
          Estoy abierto a nuevas oportunidades y colaboraciones. 
          No dudes en contactarme para discutir proyectos o simplemente saludar.
        </p>
        
        <div class="contact-links">
          <a href="mailto:ivermasco5@gmail.com" class="contact-link stagger-1">
            <div class="contact-icon" aria-hidden="true"><i class="ti ti-mail"></i></div>
            <div class="contact-details">
              <span class="contact-label">Email</span>
              <span class="contact-value">ivermasco5@gmail.com</span>
            </div>
          </a>
          
          <a href="https://www.linkedin.com/in/ibermasco" target="_blank" rel="noopener noreferrer" class="contact-link stagger-2">
            <div class="contact-icon" aria-hidden="true"><i class="ti ti-brand-linkedin"></i></div>
            <div class="contact-details">
              <span class="contact-label">LinkedIn</span>
              <span class="contact-value">linkedin.com/in/ibermasco</span>
            </div>
          </a>
          
          <div class="contact-link stagger-3">
            <div class="contact-icon" aria-hidden="true"><i class="ti ti-map-pin"></i></div>
            <div class="contact-details">
              <span class="contact-label">Ubicación</span>
              <span class="contact-value">Barranquilla, Atlántico, Colombia</span>
            </div>
          </div>
        </div>
      </div>
      
      <div class="contact-visual scroll-reveal-right">
        <div class="cta-card">
          <img
            src="/esta_persona_vestida_202604132039.png"
            alt="Retrato de Iber Masco"
            class="cta-avatar"
            loading="lazy"
          />
          <h4>¿Listo para colaborar?</h4>
          <p>Transformemos ideas en soluciones tecnológicas innovadoras</p>
          <a href="mailto:ivermasco5@gmail.com" class="btn-primary">
            <span>Enviar Email</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--color-bg-primary);
    min-height: 80vh;
    display: flex;
    align-items: center;
    position: relative;
  }
  
  .contact::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 150px;
    background: linear-gradient(180deg, var(--color-bg-secondary), transparent);
    pointer-events: none;
  }
  
  .contact-grid {
    display: grid;
    gap: var(--space-12);
    max-width: 1000px;
    margin: 0 auto;
  }
  
  .contact-info h3 {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    margin-bottom: var(--space-6);
    letter-spacing: 0.02em;
    color: var(--color-text-primary);
  }
  
  .contact-description {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-12);
    line-height: 1.8;
  }
  
  .contact-links {
    display: grid;
    gap: var(--space-6);
  }
  
  .contact-link {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-6);
    background: rgba(19, 26, 32, 0.78);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-soft);
    transition: all 0.4s var(--ease-out-quart);
    opacity: 1;
    transform: translateX(0);
  }
  
  .contact-link:hover {
    transform: translateX(8px);
    border-color: rgba(122, 195, 182, 0.36);
    box-shadow: var(--shadow-lg), var(--shadow-neon-cyan);
    background: rgba(122, 195, 182, 0.06);
  }
  
  .contact-icon {
    width: 52px;
    height: 52px;
    flex-shrink: 0;
    border-radius: 12px;
    display: grid;
    place-items: center;
    color: var(--color-accent-cyan);
    border: 1px solid rgba(122, 195, 182, 0.33);
    background: rgba(122, 195, 182, 0.08);
  }

  .contact-icon i {
    font-size: 1.45rem;
  }
  
  .contact-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  
  .contact-label {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
  }
  
  .contact-value {
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--color-accent-cyan);
  }
  
  .cta-card {
    background: linear-gradient(165deg, rgba(201, 104, 69, 0.95), rgba(143, 138, 166, 0.86));
    padding: var(--space-12);
    border-radius: var(--radius-xl);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 350px;
    box-shadow: var(--shadow-xl);
    position: relative;
    overflow: hidden;
  }
  
  .cta-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, transparent 50%);
    pointer-events: none;
  }

  .cta-avatar {
    width: 120px;
    height: 120px;
    border-radius: 999px;
    object-fit: cover;
    object-position: center top;
    border: 2px solid rgba(255, 255, 255, 0.55);
    margin-bottom: var(--space-6);
    position: relative;
    z-index: 1;
    box-shadow: 0 16px 34px rgba(0, 0, 0, 0.3);
  }
  
  .cta-card h4 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
    letter-spacing: 0.02em;
    color: #fff;
    position: relative;
    z-index: 1;
  }
  
  .cta-card p {
    font-size: var(--text-lg);
    margin-bottom: var(--space-8);
    color: rgba(255, 255, 255, 0.95);
    position: relative;
    z-index: 1;
  }
  
  .cta-card .btn-primary {
    background: #fff;
    color: #6a3f33;
    font-weight: 700;
    position: relative;
    z-index: 1;
  }
  
  .cta-card .btn-primary:hover {
    box-shadow: 0 0 40px rgba(255, 255, 255, 0.5), 0 10px 20px rgba(0, 0, 0, 0.2);
  }
  
  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

